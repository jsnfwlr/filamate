          },
          "class": {
            "type": "string",
            "description": "Material class"
          },
          "special": {
            "type": "boolean",
            "description": "Whether the material has special properties"
          }
        }
      },
      "find_store_request": {
        "type": "object",
        "description": "Request body for finding stores",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and url"
          }
        }
      },
      "update_store_request": {
        "type": "object",
        "description": "Request body for updating a store",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the store"
          },
          "url": {
            "type": "string",
            "description": "URL of the store",
            "nullable": true,
            "default": ""
          }
        }
      },
      "create_store_request": {
        "type": "object",
        "description": "Request body for updating a store",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the store"
          },
          "url": {
            "type": "string",
            "description": "URL of the store",
            "nullable": true,
            "default": ""
          }
        }
      },
      "store_item": {
        "type": "object",
        "description": "Store item",
        "required": [
          "id",
          "label",
          "url"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the store",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the store"
          },
          "url": {
            "type": "string",
            "description": "URL of the store",
            "nullable": true,
            "default": null
          }
        }
      },
      "find_color_request": {
        "type": "object",
        "description": "Request body for finding colors",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and alias"
          }
        }
      },
      "update_color_request": {
        "type": "object",
        "description": "Request body for updating a color",
        "required": [
          "label",
          "hex"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": ""
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
          }
        }
      },
      "create_color_request": {
        "type": "object",
        "description": "Request body for updating a color",
        "required": [
          "label",
          "hex"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": null
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
          }
        }
      },
      "color_item": {
        "type": "object",
        "description": "Color item",
        "required": [
          "id",
          "label",
          "hex"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the color",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": null
          }
        }
      },
      "find_spool_request": {
        "type": "object",
        "description": "Request body for finding spools",
        "properties": {
          "location_id": {
            "type": "integer",
            "description": "Filter spools by location"
          },
          "material_id": {
            "type": "integer",
            "description": "Filter spools by material"
          },
          "brand_id": {
            "type": "integer",
            "description": "Filter spools by brand"
          },
          "color_id": {
            "type": "integer",
            "description": "Filter spools by color"
          },
          "store_id": {
            "type": "integer",
            "description": "Filter spools by store"
          },
          "purchased_before": {
            "type": "string",
            "format": "date",
            "description": "Filter spools purchased before this date"
          },
          "purchased_after": {
            "type": "string",
            "format": "date",
            "description": "Filter spools purchased after this date"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether to only show spools that are empty or not - ignored if nil"
          },
          "deleted": {
            "type": "boolean",
            "description": "Whether to include deleted spools"
          }
        }
      },
      "update_spool_request": {
        "type": "object",
        "description": "Request body for updating a spool",
        "properties": {
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty"
          }
        }
      },
      "create_spool_request": {
        "type": "object",
        "description": "Request body for updating a spool",
        "required": [
          "location",
          "material",
          "store",
          "brand",
          "weight",
          "current_weight",
          "combined_weight",
          "price"
        ],
        "properties": {
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty",
            "default": false
          }
        }
      },
      "spool_item": {
        "type": "object",
        "description": "Spool item",
        "required": [
          "id",
          "location",
          "material",
          "brand",
          "colors",
          "store",
          "weight",
          "current_weight",
          "combined_weight",
          "price",
          "empty",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the spool",
            "format": "int64"
          },
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty"
          },
          "emptied_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was emptied"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was last updated"
          },
          "deleted_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was deleted"
          }
        }
      },
      "material_chart": {
        "type": "object",
        "required": [
          "labels",
          "datasets"
        ],
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels for the X Axis of the chart - typically the name of months"
          },
          "datasets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/material_chart_dataset"
            }
          }
        }
      },
      "material_chart_dataset": {
        "type": "object",
        "required": [
          "backgroundColor",
          "data"
        ],
        "properties": {
          "backgroundColor": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hex code representing the color to use for the dataset in the chart"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Data points for the dataset corresponding to each label on the X Axis"
          }
        }
      },
      "storage_chart_item": {
        "type": "object",
        "description": "Storage chart item",
        "required": [
          "labels",
          "used",
          "purchased",
          "stored"
        ],
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels for the X Axis of the chart - typically the name of months"
          },
          "used": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools used in the period"
          },
          "purchased": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools purchased in the period"
          },
          "stored": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools stored in the period"
          }
        }
      },
      "usage_stats_items": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/usage_stats_item"
        }
      },
      "usage_stats_item": {
        "type": "object",
        "description": "Usage statistics item",
        "required": [
          "color",
          "material",
          "used",
          "ordered"
        ],
        "properties": {
          "color": {
            "type": "string",
            "description": "Color(s) of the filament"
          },
          "material": {
            "type": "string",
            "description": "Material of the filament"
          },
          "used": {
            "type": "integer",
            "description": "Number of spools that have been used",
            "format": "int64"
          },
          "ordered": {
            "type": "integer",
            "description": "Number of spools that have been ordered",
            "format": "int64"
          }
        }
      },
      "storage_stats_items": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/storage_stats_item"
        }
      },
      "storage_stats_item": {
        "type": "object",
        "description": "Storage statistics item",
        "required": [
          "label",
          "max",
          "used",
          "free",
          "details"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the storage location"
          },
          "max": {
            "type": "integer",
            "description": "Total capacity of the storage location",
            "format": "int64"
          },
          "used": {
            "type": "integer",
            "description": "Amount of filament currently stored in the location",
            "format": "int64"
          },
          "free": {
            "type": "integer",
            "description": "Amount of available space in the location",
            "format": "int64"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/storage_stats_details_item"
            }
          }
        }
      },
      "storage_stats_details_item": {
        "type": "object",
        "description": "Additional details about the storage location, such as breakdown of materials stored or historical usage trends",
        "required": [
          "material",
          "brand",
          "current_weight",
          "colors_hex",
          "colors_label"
        ],
        "properties": {
          "material": {
            "type": "integer",
            "format": "int64",
            "description": "Material of the filament stored in the location"
          },
          "brand": {
            "type": "integer",
            "format": "int64",
            "description": "Brand of the filament stored in the location"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament stored in the location in grams"
          },
          "colors_hex": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hex code of the color of the filament stored in the location"
          },
          "colors_label": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Label of the color of the filament stored in the location"
          }
        }
      },
      "error": {
        "type": "object",
        "required": [
          "message",
          "code"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing the issue"
          },
          "code": {
            "type": "integer"
          }
        }
      }
    },
    "parameters": {
      "SortBy": {
        "name": "sort_by",
        "in": "query",
        "required": false,
        "description": "Field to sort by, prefixed with - for descending order (e.g. 'label' or '-created_at')",
        "schema": {
          "type": "string"
        }
      },
      "PaginateLimit": {
        "name": "paginate_limit",
        "in": "query",
        "required": false,
        "description": "The number of records to return per page (default is 50)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 50,
          "example": 20
        }
      },
      "PaginateOffset": {
        "name": "paginate_offset",
        "in": "query",
        "required": false,
        "description": "The page number to return (default is 1)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "example": 4
        }
      },
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID of the record to update",
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      }
    }
  }
}
