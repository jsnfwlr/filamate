  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message",
          "code"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing the issue"
          },
          "code": {
            "type": "integer"
          }
        }
      },
      "FindLocationRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for finding locations",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and description"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether to only show locations that can or can't be printed from - ignored if nil"
          },
          "talliable": {
            "type": "boolean",
            "description": "Whether to only show locations that can or can't be tallied - ignored if nil"
          }
        }
      },
      "UpdateLocationRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a location",
        "required": [
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from"
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied"
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location"
          }
        }
      },
      "CreateLocationRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a location",
        "required": [
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from",
            "default": false
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied",
            "default": false
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location",
            "default": 0
          }
        }
      },
      "Location": {
        "type": "object",
        "additionalProperties": false,
        "description": "Location item",
        "required": [
          "id",
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the location",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from"
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied"
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location"
          }
        }
      },
      "FindBrandRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for finding brands",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and description"
          }
        }
      },
      "UpdateBrandRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a brand",
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the brand"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the brand is still in business"
          },
          "store_id": {
            "type": "integer",
            "description": "Unique identifier for the store associated with the brand",
            "format": "int64"
          }
        }
      },
      "CreateBrandRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a brand",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the brand"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the brand is still in business",
            "default": true
          },
          "store_id": {
            "type": "integer",
            "description": "Unique identifier for the store associated with the brand",
            "format": "int64"
          }
        }
      },
      "Brand": {
        "type": "object",
        "additionalProperties": false,
        "description": "Brand item",
        "required": [
          "id",
          "label",
          "active",
          "store_id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the brand",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the brand"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the brand is still in business"
          },
          "store_id": {
            "type": "integer",
            "description": "Unique identifier for the store associated with the brand",
            "format": "int64",
            "nullable": true,
            "default": null
          }
        }
      },
      "FindMaterialRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for finding materials",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and description and class"
          },
          "class": {
            "type": "string",
            "description": "Material class to filter by"
          },
          "special": {
            "type": "boolean",
            "description": "Whether to only show materials that have or do not have special properties - ignored if nil"
          }
        }
      },
      "UpdateMaterialRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a material",
        "required": [
          "label",
          "description",
          "class",
          "special"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the material"
          },
          "description": {
            "type": "string",
            "description": "Description of the material"
          },
          "class": {
            "type": "string",
            "description": "Material class"
          },
          "special": {
            "type": "boolean",
            "description": "Whether the material has special properties"
          }
        }
      },
      "CreateMaterialRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a material",
        "required": [
          "label",
          "description",
          "class",
          "special"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the material"
          },
          "description": {
            "type": "string",
            "description": "Description of the material"
          },
          "class": {
            "type": "string",
            "description": "Material class"
          },
          "special": {
            "type": "boolean",
            "description": "Whether the material has special properties",
            "default": false
          }
        }
      },
      "Material": {
        "type": "object",
        "additionalProperties": false,
        "description": "Material item",
        "required": [
          "id",
          "label",
          "description",
          "class",
          "special"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the material",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the material"
          },
          "description": {
            "type": "string",
            "description": "Description of the material"
          },
          "class": {
            "type": "string",
            "description": "Material class"
          },
          "special": {
            "type": "boolean",
            "description": "Whether the material has special properties"
          }
        }
      },
      "FindStoreRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for finding stores",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and url"
          }
        }
      },
      "UpdateStoreRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a store",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the store"
          },
          "url": {
            "type": "string",
            "description": "URL of the store",
            "nullable": true,
            "default": ""
          }
        }
      },
      "CreateStoreRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a store",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the store"
          },
          "url": {
            "type": "string",
            "description": "URL of the store",
            "nullable": true,
            "default": ""
