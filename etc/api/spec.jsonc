      "UpdateColorRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a color",
        "required": [
          "label",
          "hex"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": ""
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
          }
        }
      },
      "CreateColorRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a color",
        "required": [
          "label",
          "hex"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": null
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
          }
        }
      },
      "Color": {
        "type": "object",
        "additionalProperties": false,
        "description": "Color item",
        "required": [
          "id",
          "label",
          "hex"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the color",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the color"
          },
          "hex": {
            "type": "string",
            "description": "Hex code of the color"
          },
          "alias": {
            "type": "string",
            "description": "Alias of the color",
            "nullable": true,
            "default": null
          }
        }
      },
      "FindSpoolRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for finding spools",
        "properties": {
          "location_id": {
            "type": "integer",
            "description": "Filter spools by location"
          },
          "material_id": {
            "type": "integer",
            "description": "Filter spools by material"
          },
          "brand_id": {
            "type": "integer",
            "description": "Filter spools by brand"
          },
          "color_id": {
            "type": "integer",
            "description": "Filter spools by color"
          },
          "store_id": {
            "type": "integer",
            "description": "Filter spools by store"
          },
          "purchased_before": {
            "type": "string",
            "format": "date",
            "description": "Filter spools purchased before this date"
          },
          "purchased_after": {
            "type": "string",
            "format": "date",
            "description": "Filter spools purchased after this date"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether to only show spools that are empty or not - ignored if nil"
          },
          "deleted": {
            "type": "boolean",
            "description": "Whether to include deleted spools"
          }
        }
      },
      "UpdateSpoolRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a spool",
        "properties": {
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty"
          }
        }
      },
      "CreateSpoolRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a spool",
        "required": [
          "location",
          "material",
          "store",
          "brand",
          "weight",
          "current_weight",
          "combined_weight",
          "price"
        ],
        "properties": {
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty",
            "default": false
          }
        }
      },
      "Spool": {
        "type": "object",
        "additionalProperties": false,
        "description": "Spool item",
        "required": [
          "id",
          "location",
          "material",
          "brand",
          "colors",
          "store",
          "weight",
          "current_weight",
          "combined_weight",
          "price",
          "empty",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the spool",
            "format": "int64"
          },
          "location": {
            "type": "integer",
            "description": "ID of the location where the spool is stored",
            "format": "int64"
          },
          "material": {
            "type": "integer",
            "description": "ID of the material of the spool",
            "format": "int64"
          },
          "brand": {
            "type": "integer",
            "description": "ID of the brand of the spool",
            "format": "int64"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "List of color IDs associated with the spool"
          },
          "store": {
            "type": "integer",
            "description": "ID of the store where the spool was purchased",
            "format": "int64"
          },
          "weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "combined_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament on the spool in grams"
          },
          "price": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Price of the filament spool at the time of purchase"
          },
          "empty": {
            "type": "boolean",
            "description": "Whether the spool is empty"
          },
          "emptied_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was emptied"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was last updated"
          },
          "deleted_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was deleted"
          }
        }
      },
      "MaterialChart": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "labels",
          "datasets"
        ],
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels for the X Axis of the chart - typically the name of months"
          },
          "datasets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MaterialChartDataset"
            }
          }
        }
      },
      "MaterialChartDataset": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "backgroundColor",
          "data"
        ],
        "properties": {
          "backgroundColor": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hex code representing the color to use for the dataset in the chart"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Data points for the dataset corresponding to each label on the X Axis"
          }
        }
      },
      "StorageChart": {
        "type": "object",
        "additionalProperties": false,
        "description": "Response body for storage chart data",
        "required": [
          "labels",
          "used",
          "purchased",
          "stored"
        ],
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels for the X Axis of the chart - typically the name of months"
          },
          "used": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools used in the period"
          },
          "purchased": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools purchased in the period"
          },
          "stored": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Number of spools stored in the period"
          }
        }
      },
      "UsageStats": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/UsageStat"
        }
      },
      "UsageStat": {
        "type": "object",
        "additionalProperties": false,
        "description": "Usage statistics item",
        "required": [
          "id",
          "color",
          "material",
          "used",
          "ordered"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the material and color combination",
            "format": "int64"
          },
          "color": {
            "type": "string",
            "description": "Color(s) of the filament"
          },
          "material": {
            "type": "string",
            "description": "Material of the filament"
          },
          "used": {
            "type": "integer",
            "description": "Number of spools that have been used",
            "format": "int64"
          },
          "ordered": {
            "type": "integer",
            "description": "Number of spools that have been ordered",
            "format": "int64"
          }
        }
      },
      "RatingStats": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/RatingStat"
        }
      },
      "RatingStat": {
        "type": "object",
        "additionalProperties": false,
        "description": "Rating statistics item",
        "required": [
          "id",
          "rating_average",
          "material",
          "brand",
          "rating_count",
          "details"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the material and brand combination",
            "format": "int64"
          },
          "rating_average": {
            "type": "number",
            "format": "float",
            "description": "Average rating of this material and brand combination, typically on a scale of 1 to 5"

          },
          "material": {
            "type": "string",
            "description": "Material of the filament"
          },
          "brand": {
            "type": "string",
            "description": "Brand of the filament"
          },
          "rating_count": {
            "type": "integer",
            "description": "Number of ratings for this material and brand combination",
            "format": "int64"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RatingStatDetail"
            },
            "description": "Detailed information about each rating for this material and brand combination"
          }
        }
      },
      "RatingStatDetail": {
        "type": "object",
        "additionalProperties": false,
        "description": "Additional details about the ratings that contribute to the overall rating statistics for a material and brand combination - individual ratings by spool",
        "required": [
          "spool_id",
          "spool_created_at",
          "spool_weight",
          "spool_colors",
          "rating",
          "rating_created_at"
        ],
        "properties": {
          "spool_id": {
            "type": "integer",
            "description": "Unique identifier for the spool",
            "format": "int64"
          },
          "spool_created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the spool was created"
          },
          "spool_weight": {
            "type": "number",
            "format": "float",
            "description": "Initial marketed weight of the filament on the spool in grams"
          },
          "spool_colors": {
            "type": "array",
            "items": {
              "type": "integer",
              "description": "ID of the color of the spool",
              "format": "int64"
            },
            "description": "Color ID(s) of the filament on the spool"
          },
          "rating": {
            "type": "integer",
            "description": "Unique identifier for the rating",
            "minimum":1,
            "maximum":5,
            "format": "int64"
          },
          "rating_created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the rating was created"
          }
        }
      },
      "StorageStats": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/StorageStat"
        }
      },
      "StorageStat": {
        "type": "object",
        "additionalProperties": false,
        "description": "Storage statistics item",
        "required": [
          "id",
          "label",
          "max",
          "used",
          "free",
          "details"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the storage stat entry",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the storage location"
          },
          "max": {
            "type": "integer",
            "description": "Total capacity of the storage location",
            "format": "int64"
          },
          "used": {
            "type": "integer",
            "description": "Amount of filament currently stored in the location",
            "format": "int64"
          },
          "free": {
            "type": "integer",
            "description": "Amount of available space in the location",
            "format": "int64"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StorageStatsDetails"
            }
          }
        }
      },
      "StorageStatsDetails": {
        "type": "object",
        "additionalProperties": false,
        "description": "Additional details about the storage location, such as breakdown of materials stored or historical usage trends",
        "required": [
          "material",
          "brand",
          "current_weight",
          "colors_hex",
          "colors_label"
        ],
        "properties": {
          "material": {
            "type": "integer",
            "format": "int64",
            "description": "Material of the filament stored in the location"
          },
          "brand": {
            "type": "integer",
            "format": "int64",
            "description": "Brand of the filament stored in the location"
          },
          "current_weight": {
            "type": "string",
            "pattern": "[0-9]+\\.[0-9]{2}",
            "description": "Current weight of the filament stored in the location in grams"
          },
          "colors_hex": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hex code of the color of the filament stored in the location"
          },
          "colors_label": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Label of the color of the filament stored in the location"
          }
        }
      },
      "UpdateRatingRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for updating a rating",
        "required": [
          "id",
          "rating"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID of the rating to update",
            "format": "int64"
          },
          "rating": {
            "type": "integer",
            "description": "Updated rating value for the spool, typically on a scale of 1 to 5",
            "minimum": 1,
            "maximum": 5,
            "format": "int64"
          }
        }
      },
      "CreateRatingRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Request body for creating a rating",
        "required": [
          "spool_id",
          "rating"
        ],
        "properties": {
          "spool_id": {
            "type": "integer",
            "description": "ID of the spool being rated",
            "format": "int64"
          },
          "rating": {
            "type": "integer",
            "description": "Rating value for the spool, typically on a scale of 1 to 5",
            "minimum": 1,
            "maximum": 5,
            "format": "int64"
          }
        }
      },
      "Rating": {
        "type": "object",
        "additionalProperties": false,
        "description": "Rating item",
        "required": [
          "id",
          "spool_id",
          "rating",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the rating",
            "format": "int64"
          },
          "spool_id": {
            "type": "integer",
            "description": "ID of the spool being rated",
            "format": "int64"
          },
          "rating": {
            "type": "integer",
            "description": "Rating value for the spool, typically on a scale of 1 to 5",
            "minimum": 1,
            "maximum": 5,
            "format": "int64"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the rating was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the rating was last updated"
          }
        }
      }
    },
    "parameters": {
      "SortBy": {
        "name": "sort_by",
        "in": "query",
        "required": false,
        "description": "Field to sort by, prefixed with - for descending order (e.g. 'label' or '-created_at')",
        "schema": {
          "type": "string"
        }
      },
      "PaginateLimit": {
        "name": "paginate_limit",
        "in": "query",
        "required": false,
        "description": "The number of records to return per page (default is 50)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 50,
          "example": 20
        }
      },
      "PaginateOffset": {
        "name": "paginate_offset",
        "in": "query",
        "required": false,
        "description": "The page number to return (default is 1)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "example": 4
        }
      },
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID of the record to update",
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "BrandID": {
        "name": "brand_id",
        "in": "query",
        "required": false,
        "description": "ID of the brand to filter by",
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "MaterialID": {
        "name": "material_id",
        "in": "query",
        "required": false,
        "description": "ID of the material to filter by",
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      }
    }
  }
}
