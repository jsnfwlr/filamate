{
  "openapi": "3.0.0",
  "info": {
    "version": "0.1.0",
    "title": "Filamate Backend API"
  },
  "paths": {
    "/api/health/check": {
      "get": {
        "operationId": "health_check",
        "summary": "Get health status",
        "description": "Get the health status of the server.",
        "responses": {
          "200": {
            "description": "Health check successful"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      }
    },
    "/api/locations": {
      "options": {
        "operationId": "check_locations",
        "summary": "CORS preflight for locations",
        "description": "CORS preflight request for /locations endpoint.",
        "responses": {
          "204": {
            "description": "CORS preflight successful"
          }
        }
      },
      "get": {
        "operationId": "find_locations",
        "summary": "Find locations",
        "description": "Retrieve a list of all locations.",
        "responses": {
          "200": {
            "description": "List of locations retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/location_item"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create_location",
        "summary": "Create location",
        "description": "Create a new location.",
        "responses": {
          "201": {
            "description": "Location created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/location_item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "Location creation payload",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/create_location_request"
              }
            }
          }
        }
      }
    },
    "/api/location/{id}": {
      "options": {
        "operationId": "check_location",
        "summary": "CORS preflight for location by ID",
        "description": "CORS preflight request for /location/{id} endpoint.",
        "responses": {
          "204": {
            "description": "CORS preflight successful"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          }
        ]
      },
      "patch": {
        "operationId": "update_location",
        "summary": "Update location",
        "description": "Update an existing location by ID.",
        "responses": {
          "200": {
            "description": "location updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/location_item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "location not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "requestBody": {
          "description": "location update payload",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/update_location_request"
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "kill_location",
        "summary": "Delete location",
        "description": "Delete an existing location by ID.",
        "responses": {
          "204": {
            "description": "location deleted successfully"
          },
          "404": {
            "description": "location not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          }
        ]
      }
    },
