            "type": "string",
            "description": "Name of the brand"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the brand is still in business"
          },
          "store_id": {
            "type": "integer",
            "description": "Unique identifier for the store associated with the brand",
            "format": "int64"
          }
        }
      },
      "create_brand_request": {
        "type": "object",
        "description": "Request body for updating a brand",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the brand"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the brand is still in business",
            "default": true
          },
          "store_id": {
            "type": "integer",
            "description": "Unique identifier for the store associated with the brand",
            "format": "int64"
          }
        }
      },
      "brand_item": {
