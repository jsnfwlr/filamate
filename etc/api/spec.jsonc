  "components": {
    "schemas": {
      "find_location_request": {
        "type": "object",
        "description": "Request body for finding locations",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and description"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether to only show locations that can or can't be printed from - ignored if nil"
          },
          "talliable": {
            "type": "boolean",
            "description": "Whether to only show locations that can or can't be tallied - ignored if nil"
          }
        }
      },
      "update_location_request": {
        "type": "object",
        "description": "Request body for updating a location",
        "required": [
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from"
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied"
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location"
          }
        }
      },
      "create_location_request": {
        "type": "object",
        "description": "Request body for updating a location",
        "required": [
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from",
            "default": false
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied",
            "default": false
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location",
            "default": 0
          }
        }
      },
      "location_item": {
        "type": "object",
        "description": "Location item",
        "required": [
          "id",
          "label",
          "description",
          "printable",
          "tally",
          "capacity"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the location",
            "format": "int64"
          },
          "label": {
            "type": "string",
            "description": "Name of the location"
          },
          "description": {
            "type": "string",
            "description": "Description of the location"
          },
          "printable": {
            "type": "boolean",
            "description": "Whether the location can be printed from"
          },
          "tally": {
            "type": "boolean",
            "description": "Whether the location can be tallied"
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of the location"
          }
        }
      },
      "find_brand_request": {
        "type": "object",
        "description": "Request body for finding brands",
        "properties": {
          "search": {
            "type": "string",
            "description": "Regex-capable term to search against the label and description"
